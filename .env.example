# Identika WB AI — copy to .env and adjust for local dev

# Provider: mock (default, no external APIs) or openrouter
IDENTIKA_PROVIDER=mock

# Server
IDENTIKA_HOST=127.0.0.1
IDENTIKA_PORT=8787

# Storage paths (relative to project root)
IDENTIKA_DB_PATH=./data/identika.sqlite
IDENTIKA_ASSETS_DIR=./assets

# Optional reverse-proxy base path (empty for root)
IDENTIKA_PUBLIC_BASE_PATH=

# WB Tool integration (BASE_URL = server-side API; PUBLIC_URL = shown in dashboard UI)
WB_TOOL_BASE_URL=http://127.0.0.1:8765
WB_TOOL_PUBLIC_URL=

# OpenRouter (required when IDENTIKA_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# AI image generation (auto-enabled when provider=openrouter; set false to force mock images)
IDENTIKA_ENABLE_AI_IMAGES=

# Production auth (optional — unset for local dev without auth)
IDENTIKA_API_KEY=
IDENTIKA_UI_PASSWORD=
